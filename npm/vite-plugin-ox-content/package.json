{
  "name": "@ox-content/vite-plugin",
  "version": "2.3.0",
  "description": "Vite plugin for Ox Content - High-performance Markdown processing with Environment API",
  "keywords": [
    "environment-api",
    "markdown",
    "ox-content",
    "ssg",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/ox-content.git",
    "directory": "npm/vite-plugin-ox-content"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "typecheck": "tsgo --noEmit",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@ox-content/napi": "workspace:*",
    "glob": "^11.0.0",
    "playwright": "^1.59.1",
    "puppeteer": "^23.11.1",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "rolldown": "^1.0.0-rc.1",
    "shiki": "^1.24.0",
    "typescript": "catalog:",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/hast": "^3.0.4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.0.0",
    "vite": "catalog:",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
