{
  "name": "@ox-content/vite-plugin-vue",
  "version": "2.2.0",
  "description": "Vue integration for Ox Content - Embed Vue components in Markdown",
  "keywords": [
    "markdown",
    "mdx",
    "ox-content",
    "vite",
    "vite-plugin",
    "vue"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/ox-content.git",
    "directory": "npm/vite-plugin-ox-content-vue"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@ox-content/islands": "workspace:*",
    "@ox-content/vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vite": "catalog:",
    "vue": "catalog:"
  }
}
